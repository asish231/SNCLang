fn sum_primes(int limit) -> int {
    let sum = 0
    let i = 2
    while (i <= limit) {
        let is_prime = true
        let j = 2
        while (j * j <= i) {
            if (i % j == 0) {
                is_prime = false
            }
            j = j + 1
        }
        if (is_prime) {
            sum = sum + i
        }
        i = i + 1
    }
    return sum
}

fn main() {
    let result = sum_primes(5000)
    print(result)
}