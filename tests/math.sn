fn abs(int x) -> int {
    if (x < 0) {
        return -x
    }
    return x
}

fn max(int a, int b) -> int {
    if (a > b) {
        return a
    }
    return b
}

fn min(int a, int b) -> int {
    if (a < b) {
        return a
    }
    return b
}

fn pow(int base, int exp) -> int {
    int res = 1
    int i = 0
    while (i < exp) {
        res = res * base
        i = i + 1
    }
    return res
}

fn clamp(int val, int low, int high) -> int {
    if (val < low) {
        return low
    }
    if (val > high) {
        return high
    }
    return val
}

fn sign(int x) -> int {
    if (x > 0) {
        return 1
    }
    if (x < 0) {
        return -1
    }
    return 0
}
