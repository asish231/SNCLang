// SNlang Hard DSA Suite
// 1. Sudoku Solver (Backtracking)
// 2. Trapping Rain Water (Two Pointers)

// --- Sudoku Solver ---

fn is_safe(list<int> board, int row, int col, int num) -> bool {
    // Check row
    for (int i = 0, i < 9, i += 1) {
        if (board[row * 9 + i] == num) {
            return false
        }
    }
    
    // Check column
    for (int i = 0, i < 9, i += 1) {
        if (board[i * 9 + col] == num) {
            return false
        }
    }
    
    // Check 3x3 box
    int start_row = (row / 3) * 3
    int start_col = (col / 3) * 3
    for (int i = 0, i < 3, i += 1) {
        for (int j = 0, j < 3, j += 1) {
            if (board[(start_row + i) * 9 + (start_col + j)] == num) {
                return false
            }
        }
    }
    
    return true
}

fn solve_sudoku(list<int> board) -> bool {
    for (int row = 0, row < 9, row += 1) {
        for (int col = 0, col < 9, col += 1) {
            if (board[row * 9 + col] == 0) {
                for (int num = 1, num <= 9, num += 1) {
                    if (is_safe(board, row, col, num)) {
                        board[row * 9 + col] = num
                        if (solve_sudoku(board)) {
                            return true
                        }
                        board[row * 9 + col] = 0
                    }
                }
                return false
            }
        }
    }
    return true
}

fn print_board(list<int> board) {
    for (int i = 0, i < 9, i += 1) {
        str row_str = ""
        for (int j = 0, j < 9, j += 1) {
            row_str = row_str + cast(board[i * 9 + j], str) + " "
        }
        print(row_str)
    }
}

// --- Trapping Rain Water ---

fn trap_rain_water(list<int> height) -> int {
    int n = height.length()
    if (n <= 2) {
        return 0
    }
    
    int left = 0
    int right = n - 1
    int left_max = 0
    int right_max = 0
    int total_water = 0
    
    while (left < right) {
        if (height[left] < height[right]) {
            if (height[left] >= left_max) {
                left_max = height[left]
            } else {
                total_water = total_water + (left_max - height[left])
            }
            left = left + 1
        } else {
            if (height[right] >= right_max) {
                right_max = height[right]
            } else {
                total_water = total_water + (right_max - height[right])
            }
            right = right - 1
        }
    }
    
    return total_water
}

// --- Main ---

fn main() {
    print("=== SNlang Hard DSA Suite ===")
    
    // 1. Sudoku
    print("")
    print("Problem 1: Sudoku Solver")
    list<int> board = [
        5, 3, 0, 0, 7, 0, 0, 0, 0,
        6, 0, 0, 1, 9, 5, 0, 0, 0,
        0, 9, 8, 0, 0, 0, 0, 6, 0,
        8, 0, 0, 0, 6, 0, 0, 0, 3,
        4, 0, 0, 8, 0, 3, 0, 0, 1,
        7, 0, 0, 0, 2, 0, 0, 0, 6,
        0, 6, 0, 0, 0, 0, 2, 8, 0,
        0, 0, 0, 4, 1, 9, 0, 0, 5,
        0, 0, 0, 0, 8, 0, 0, 7, 9
    ]
    
    print("Initial Board:")
    print_board(board)
    
    if (solve_sudoku(board)) {
        print("Solved Board:")
        print_board(board)
    } else {
        print("No solution exists")
    }
    
    // 2. Trapping Rain Water
    print("")
    print("Problem 2: Trapping Rain Water")
    list<int> heights = [0, 1, 0, 2, 1, 0, 1, 3, 2, 1, 2, 1]
    int trapped = trap_rain_water(heights)
    print("Heights: [0, 1, 0, 2, 1, 0, 1, 3, 2, 1, 2, 1]")
    print("Trapped Water: " + cast(trapped, str))
}
