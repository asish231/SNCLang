fn main() {
    let sum = 0
    let i = 0
    while (i < 1000) {
        let j = 0
        while (j < 1000) {
            let k = 0
            while (k < 100) {
                sum = sum + 1
                k = k + 1
            }
            j = j + 1
        }
        i = i + 1
    }
    print(sum)
}