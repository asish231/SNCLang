fn toBinaryStr(int n) -> str {
    if (n == 0) {
        return "0"
    }

    int value = n
    str bits = ""

    while (value > 0) {
        int bit = value % 2
        bits = cast(bit, str) + bits
        value = value / 2
    }

    return bits
}

fn main() {
    print(toBinaryStr(5))    // 101
    print(toBinaryStr(10))   // 1010
    print(toBinaryStr(19))   // 10011
}
