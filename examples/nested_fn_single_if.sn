// Note: nested fn definitions have a known slot-reuse bug on multiple calls.
// This example uses top-level functions instead.

fn inner(int y) -> str {
    if (y > 0) {
        return "positive"
    }
    return "not positive"
}

fn outer(int x) -> str {
    return inner(x)
}

fn main() {
    print(outer(4))
    print(outer(-2))
}
