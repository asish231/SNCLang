fn is_even(int n) -> bool {
    if (n % 2 == 0) {
        return true
    }
    return false
}

fn is_positive(int n) -> bool {
    if (n > 0) {
        return true
    }
    return false
}

fn process(int n) -> str {
    if (n % 2 == 0) {
        return "even"
    }
    return "odd"
}

fn get_zero() -> int {
    return 0
}

fn main() {
    is_even(4)
    is_even(5)
    is_positive(4)
    is_positive(5)
    is_positive(6)
    process(4)
    get_zero()
}